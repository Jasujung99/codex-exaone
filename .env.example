# FriendliAI / EXAONE PoC settings
# 1) Create/copy an API key from FriendliAI.
# 2) Copy this file to .env.local for local development or set the same keys in your deploy environment.
# 3) Do not commit real API keys.
FRIENDLI_API_KEY=

# FriendliAI OpenAI-compatible base URL. Verify in FriendliAI docs/dashboard before production use.
FRIENDLI_BASE_URL=https://api.friendli.ai/serverless/v1

# For Model APIs/serverless, use the provider model id shown on the model page.
# For Dedicated Endpoints, Friendli docs say to paste the endpoint ID into the model field.
# Start with K-EXAONE for Korean/reasoning quality tests, then compare EXAONE 4.0 variants if enabled in your account.
FRIENDLI_MODEL=LGAI-EXAONE/K-EXAONE-236B-A23B

# Optional comma-separated candidate list used by PoC scripts or manual tests.
# Replace/add exact IDs from the FriendliAI dashboard because availability can differ by account/endpoint type.
FRIENDLI_MODEL_CANDIDATES=LGAI-EXAONE/K-EXAONE-236B-A23B,LGAI-EXAONE/EXAONE-4.0-32B,LGAI-EXAONE/EXAONE-4.0-1.2B

# PoC generation defaults. Keep conservative until cost/quality is measured.
FRIENDLI_TEMPERATURE=0.4
FRIENDLI_TOP_P=0.9
FRIENDLI_MAX_TOKENS=2500

# Optional budget guardrails for future adapter code.
DAILY_GENERATION_LIMIT=20
REQUEST_MAX_INPUT_TOKENS=2000
REQUEST_MAX_OUTPUT_TOKENS=4000
MONTHLY_COST_SOFT_LIMIT_USD=3
